# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=geus_gas_detection
POSTGRES_USER=geus_user
POSTGRES_PASSWORD=cambiame_wachin

# InfluxDB Configuration
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=cambiame_wachin
INFLUXDB_ORG=geus
INFLUXDB_BUCKET=sensor_readings

# RabbitMQ Configuration
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# MQTT Configuration
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=8883
MQTT_BROKER_PORT_WS=9001
MQTT_USE_TLS=true
MQTT_CA_CERT_PATH=/etc/mosquitto/certs/ca.crt
MQTT_CLIENT_CERT_PATH=/etc/mosquitto/certs/client.crt
MQTT_CLIENT_KEY_PATH=/etc/mosquitto/certs/client.key

# Redis Configuration (optional, for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=4

# Security
JWT_SECRET_KEY=cambiame_wachin
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Application Settings
APP_NAME=GEUS Gas Detection System
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true

# Gas Detection Thresholds (ppm)
GAS_THRESHOLD_WARNING=200
GAS_THRESHOLD_CRITICAL=500

# Safety Settings
TEST_MODE_TIMEOUT_MINUTES=30
ALERT_NOTIFICATION_TIMEOUT_SECONDS=30
DATA_RETENTION_DAYS=180

# Email Notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASSWORD=cambiame_wachin
SMTP_FROM_EMAIL=noreply@geus.example.com

# Push Notifications (optional)
FIREBASE_CREDENTIALS_PATH=/path/to/firebase-credentials.json

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
